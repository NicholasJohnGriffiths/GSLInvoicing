@model IEnumerable<GSLInvoicing.Web.Models.AppUser>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Users</h1>
    <a asp-action="Create" class="btn btn-primary">New User</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Vendor</th>
                    <th>User Type</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var appUser in Model)
            {
                <tr>
                    <td>@appUser.UserName</td>
                    <td>@appUser.Email</td>
                    <td>@appUser.Phone</td>
                    <td>@appUser.Vendor?.Name</td>
                    <td>@appUser.UserType</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@appUser.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@appUser.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>