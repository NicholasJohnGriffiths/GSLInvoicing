@model GSLInvoicing.Web.Models.Client

@{
    ViewData["Title"] = "Create Client";
    var isVendorSelectionLocked = ViewBag.IsVendorSelectionLocked == true;
}

<h1 class="h3">Create Client</h1>

<form asp-controller="Clients" asp-action="Create" method="post" class="mt-3" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    @if (ViewBag.AllowVendorSelection == true)
    {
        <div class="mb-3">
            <label asp-for="VendorId" class="form-label">Vendor</label>
            @if (isVendorSelectionLocked)
            {
                <select asp-for="VendorId" asp-items="ViewBag.VendorOptions" class="form-select" disabled>
                    <option value="">Select vendor</option>
                </select>
                <input asp-for="VendorId" type="hidden" />
            }
            else
            {
                <select asp-for="VendorId" asp-items="ViewBag.VendorOptions" class="form-select">
                    <option value="">Select vendor</option>
                </select>
            }
            <span asp-validation-for="VendorId" class="text-danger"></span>
        </div>
    }
    else
    {
        <input asp-for="VendorId" type="hidden" />
    }

    <div class="mb-3">
        <label asp-for="CardId" class="form-label"></label>
        <input class="form-control" value="Auto-generated on save" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Contact" class="form-label"></label>
        <input asp-for="Contact" class="form-control" />
        <span asp-validation-for="Contact" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="TransactionReference" class="form-label">Transaction Reference</label>
        <input asp-for="TransactionReference" class="form-control" />
        <span asp-validation-for="TransactionReference" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="BankAccount" class="form-label">Bank Account</label>
        <input asp-for="BankAccount" class="form-control" />
        <span asp-validation-for="BankAccount" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Street" class="form-label"></label>
        <input asp-for="Street" class="form-control" />
        <span asp-validation-for="Street" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Suburb" class="form-label"></label>
        <input asp-for="Suburb" class="form-control" />
        <span asp-validation-for="Suburb" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="City" class="form-label"></label>
        <input asp-for="City" class="form-control" />
        <span asp-validation-for="City" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Postcode" class="form-label"></label>
        <input asp-for="Postcode" class="form-control" />
        <span asp-validation-for="Postcode" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Country" class="form-label"></label>
        <input asp-for="Country" class="form-control" />
        <span asp-validation-for="Country" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="GSTCode" class="form-label"></label>
        <select asp-for="GSTCode" asp-items="ViewBag.GstCodeOptions" class="form-select">
            <option value="">Select GST code</option>
        </select>
        <span asp-validation-for="GSTCode" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Rate" class="form-label"></label>
        <input asp-for="Rate" class="form-control" />
        <span asp-validation-for="Rate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DateCreated" class="form-label"></label>
        <input asp-for="DateCreated" asp-format="{0:yyyy-MM-dd}" type="date" class="form-control" />
        <span asp-validation-for="DateCreated" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Back</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
