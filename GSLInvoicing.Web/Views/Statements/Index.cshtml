@model GSLInvoicing.Web.Models.ViewModels.StatementPageViewModel

@{
    ViewData["Title"] = "Statements";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Statements</h1>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<form asp-action="Index" method="get" class="card card-body mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label for="fromDate" class="form-label">From</label>
            <input id="fromDate" name="fromDate" type="date" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3">
            <label for="toDate" class="form-label">To</label>
            <input id="toDate" name="toDate" type="date" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-4">
            <label for="clientId" class="form-label">Client</label>
            <select id="clientId" name="clientId" class="form-select" asp-items="Model.ClientOptions">
                <option value="">Select client...</option>
            </select>
        </div>
        <div class="col-md-4">
            <label for="outputFolderPath" class="form-label">PDF Output Folder</label>
            <input id="outputFolderPath" name="outputFolderPath" class="form-control" value="@Model.OutputFolderPath" placeholder="Absolute path or relative to app root" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">Load Statement</button>
        </div>
    </div>
</form>

@if (Model.HasStatement)
{
    <div class="card card-body mb-3">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <div class="h5 mb-1">@Model.ClientName</div>
                <div>@Model.ClientContact</div>
                <div>@Model.ClientEmail</div>
                <div class="text-muted small">Period: @Model.FromDate.ToString("yyyy-MM-dd") to @Model.ToDate.ToString("yyyy-MM-dd")</div>
            </div>
            <div class="d-flex gap-2">
                <form asp-action="Download" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="FromDate" />
                    <input type="hidden" asp-for="ToDate" />
                    <input type="hidden" asp-for="SelectedClientId" />
                    <input type="hidden" asp-for="OutputFolderPath" />
                    <button type="submit" class="btn btn-outline-secondary">Download PDF</button>
                </form>
                <form asp-action="Print" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="FromDate" />
                    <input type="hidden" asp-for="ToDate" />
                    <input type="hidden" asp-for="SelectedClientId" />
                    <input type="hidden" asp-for="OutputFolderPath" />
                    <button type="submit" class="btn btn-primary">Print</button>
                </form>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Detail</th>
                    <th>Particulars</th>
                    <th>Code</th>
                    <th>Reference</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Running Balance</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Transactions.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-muted">No transactions for this period.</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model.Transactions)
                {
                    <tr>
                        <td>@row.TransDate.ToString("yyyy-MM-dd")</td>
                        <td>@row.TransType</td>
                        <td>@row.Detail</td>
                        <td>@row.Particulars</td>
                        <td>@row.Code</td>
                        <td>@row.Reference</td>
                        <td class="text-end">@row.Amount.ToString("C2")</td>
                        <td class="text-end">@row.RunningBalance.ToString("C2")</td>
                    </tr>
                }
            }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="7" class="text-end">Closing Balance</th>
                    <th class="text-end">@Model.ClosingBalance.ToString("C2")</th>
                </tr>
            </tfoot>
        </table>
    </div>
}
